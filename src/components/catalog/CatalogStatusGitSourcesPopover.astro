---
import Badge from '../ui/Badge.astro';
import {
  getGitSourceSyncBadge,
  summarizeGitSourceError,
} from '../../lib/catalog-status';
import type { GitSourceSyncStatus } from '../../lib/catalog/sources';

export interface GitSourceItem {
  name: string;
  repoUrl: string;
  branch: string;
  checkoutPath: string;
  scanPaths?: string[];
  syncStatus?: GitSourceSyncStatus;
}

export interface Props {
  gitSources: GitSourceItem[];
  summaryLabel: string;
  countLabel: string;
}

const { gitSources, summaryLabel, countLabel } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  dateStyle: 'medium',
  timeStyle: 'short',
});
---

<!-- Small details popover for managed Git source metadata in the configuration tab. -->
<details class="catalog-status-popover" data-catalog-status-popover>
  <summary class="catalog-status-popover-toggle" aria-label={summaryLabel} title={summaryLabel}>
    <span class="catalog-status-popover-count">{countLabel}...</span>
    <span class="sr-only">{summaryLabel}</span>
  </summary>

  <div class="catalog-status-popover-panel">
    <div class="catalog-status-source-list">
      {gitSources.map((source, index) => {
        const syncBadge = getGitSourceSyncBadge(source.syncStatus);
        const syncHint = summarizeGitSourceError(source.syncStatus?.lastError);

        return (
          <section class="catalog-status-source-card" aria-label={`Git source ${index + 1}`}>
            <div class="catalog-status-source-header gap-2">
              <h3 class="catalog-status-source-title">{source.name}</h3>
              <div class="flex flex-wrap items-center justify-end gap-2">
                <Badge tone={syncBadge.tone}>{syncBadge.label}</Badge>
                <span class="catalog-status-source-branch">{source.branch}</span>
              </div>
            </div>

            <dl class="catalog-status-source-details">
              <dt class="muted">Repo</dt>
              <dd class="min-w-0 break-all text-slate-700"><code>{source.repoUrl}</code></dd>

              <dt class="muted">Scan</dt>
              <dd class="min-w-0 wrap-break-word text-slate-700">{source.scanPaths ? source.scanPaths.join(', ') : '(repo root)'}</dd>

              {source.syncStatus?.lastSyncFinishedAt && (
                <>
                  <dt class="muted">Last sync</dt>
                  <dd class="min-w-0 wrap-break-word text-slate-700">{dateFormatter.format(new Date(source.syncStatus.lastSyncFinishedAt))}</dd>
                </>
              )}

              {syncHint && (
                <>
                  <dt class="muted">Issue</dt>
                  <dd class="min-w-0 wrap-break-word text-warn">{syncHint}</dd>
                </>
              )}
            </dl>
          </section>
        );
      })}
    </div>
  </div>
</details>

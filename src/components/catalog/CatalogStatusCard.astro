---
import Badge from '../ui/Badge.astro';
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';

export interface Props {
  servicesCount: number;
  servicesValid: number;
  servicesWithIssues: number;
  generatedAt: string;
  buildVersion: string;
  snapshotStatus: 'fresh' | 'stale';
  snapshotError?: string;
  localCatalogPath?: string;
}

const {
  servicesCount,
  servicesValid,
  servicesWithIssues,
  generatedAt,
  buildVersion,
  snapshotStatus,
  snapshotError,
  localCatalogPath,
} = Astro.props;

const detailItems = [
  { label: 'Generated', value: new Date(generatedAt).toLocaleString('en-GB') },
  { label: 'Snapshot', value: snapshotStatus === 'fresh' ? 'Fresh' : 'Stale, serving last good catalog' },
  { label: 'Build', value: buildVersion },
  ...(localCatalogPath ? [{ label: 'Local catalog', value: localCatalogPath }] : []),
  ...(snapshotError ? [{ label: 'Last refresh error', value: snapshotError }] : []),
];
---

<Card as="aside" class="p-6">
  <SectionTitle class="mb-4 text-lg">Catalog status</SectionTitle>

  <div class="flex flex-wrap gap-2">
    <Badge tone="ok">{servicesCount} services</Badge>
    <Badge tone="ok">{servicesValid} valid</Badge>
    {servicesWithIssues > 0 ? <Badge tone="warn">{servicesWithIssues} warnings</Badge> : <Badge>No warnings</Badge>}
    <Badge tone={snapshotStatus === 'fresh' ? 'ok' : 'warn'}>{snapshotStatus}</Badge>
  </div>

  <dl class="mt-4 grid gap-x-4 gap-y-2 text-[0.95rem] leading-6 sm:grid-cols-[auto_minmax(0,1fr)]">
    {detailItems.map((item) => (
      <>
        <dt class="muted font-medium">{item.label}</dt>
        <dd class="min-w-0 break-words text-slate-700">{item.label === 'Local catalog' ? <code>{item.value}</code> : item.value}</dd>
      </>
    ))}
  </dl>
</Card>

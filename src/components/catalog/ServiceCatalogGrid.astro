---
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import CatalogKindIcon from './CatalogKindIcon.astro';
import Icon from '../ui/Icon.astro';
import ServiceCardGrid from './ServiceCardGrid.astro';
import { toAppPath } from '../../lib/paths';
import type { ServiceRecord } from '../../lib/catalog';
import { normalizeCatalogKind } from '../../lib/catalog-kind-icon';
import ServiceCompactList from './ServiceCompactList.astro';

export interface Props {
  services: ServiceRecord[];
  catalogPath?: string;
}

const { services } = Astro.props;
const toggleId = 'catalog-view-toggle';

const uniqueKinds = [...new Set(services.map((s) => normalizeCatalogKind(s.data.kind) || 'service'))].sort();
const showKindFilter = uniqueKinds.length > 1;
const kindLabel = (k: string) => k.charAt(0).toUpperCase() + k.slice(1);

// Platform grouping
const platformLabel = (p: string) =>
  p.charAt(0).toUpperCase() + p.slice(1).replace(/-/g, ' ');

const platformGroups: { platform: string; label: string; services: ServiceRecord[] }[] = [];
const platformMap = new Map<string, ServiceRecord[]>();
const noPlatform: ServiceRecord[] = [];

for (const s of services) {
  const p = s.data.platform?.trim();
  if (p) {
    if (!platformMap.has(p)) platformMap.set(p, []);
    platformMap.get(p)!.push(s);
  } else {
    noPlatform.push(s);
  }
}

for (const [p, svcs] of [...platformMap.entries()].sort(([a], [b]) => a.localeCompare(b))) {
  platformGroups.push({ platform: p, label: platformLabel(p), services: svcs });
}
if (noPlatform.length > 0) {
  platformGroups.push({ platform: '', label: 'Other', services: noPlatform });
}

const showPlatformToggle = platformGroups.length > 1;

// Pre-compute global column widths for consistent alignment across all groups
const globalIdWidthCh = Math.max(...services.map((s) => s.data.id.length), 8);
const globalTagsWidthCh = Math.max(
  ...services.map((s) =>
    (s.data.tags ?? []).reduce((total, tag, i) => total + tag.length + (i > 0 ? 4 : 1), 0),
  ),
  12,
);

// Flat-sorted service list: by platform (alpha), then no-platform last
const sortedServices = [
  ...platformGroups.flatMap((g) => g.services),
];
---

{
  services.length > 0 ? (
    <section data-catalog-view-root>
      <div class="mb-2 flex items-center gap-3">
        <input
          type="search"
          data-catalog-search
          placeholder="Search by name or id…"
          autocomplete="off"
          spellcheck="false"
          class="min-w-0 flex-1 rounded-xl border border-[var(--color-border)] bg-white/85 px-4 py-2 text-[0.95rem] text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-200"
        />

        <div class="flex shrink-0 items-center gap-3">
          {showKindFilter && (
            <div class="inline-flex items-center gap-1" role="group" aria-label="Filter by kind">
              {uniqueKinds.map((kind) => (
                <button
                  type="button"
                  class="kind-filter-btn"
                  data-kind-filter-btn={kind}
                  title={kindLabel(kind)}
                  aria-pressed="false"
                >
                  <CatalogKindIcon kind={kind} size={15} />
                </button>
              ))}
            </div>
          )}

          <div class="inline-flex rounded-full border border-[var(--color-border)] bg-white/80 p-1 shadow-sm" role="group" aria-label="Catalog view mode" id={toggleId}>
            <button type="button" class="catalog-view-toggle is-active" data-catalog-view-button data-view="list" aria-pressed="true">
              List
            </button>
            <button type="button" class="catalog-view-toggle" data-catalog-view-button data-view="cards" aria-pressed="false">
              Cards
            </button>
            {showPlatformToggle && (
              <>
                <span class="mx-1 w-px self-stretch bg-[var(--color-border)]" aria-hidden="true" />
                <button
                  type="button"
                  class="catalog-view-toggle"
                  data-platform-group-toggle
                  title="Group by platform"
                  aria-pressed="false"
                >
                  Group
                </button>
              </>
            )}
          </div>
        </div>
      </div>

      <div class="mb-3 flex flex-wrap items-center gap-4">
        <p class="muted text-[0.95rem]" data-catalog-count>Showing {services.length} service{services.length === 1 ? '' : 's'}</p>
        <a href={toAppPath('/tags')} class="text-[0.95rem]">Browse tags</a>
      </div>

      {/* List view */}
      <div data-catalog-view-panel data-view="list">
        {/* Flat list (default) */}
        <div data-platform-view="flat">
          <ServiceCompactList
            services={sortedServices}
            idColumnWidthCh={globalIdWidthCh}
            tagsColumnWidthCh={globalTagsWidthCh}
          />
        </div>

        {/* Grouped list (shown when platform grouping is active) */}
        <div data-platform-view="grouped" hidden>
          {platformGroups.map((group) => (
            <div class="platform-section" data-platform-section={group.platform || '__other__'}>
              <div class="platform-section-header">
                <span class="platform-section-label">{group.label}</span>
                <span class="platform-section-count" data-platform-count>{group.services.length}</span>
              </div>
              <ServiceCompactList
                services={group.services}
                idColumnWidthCh={globalIdWidthCh}
                tagsColumnWidthCh={globalTagsWidthCh}
              />
            </div>
          ))}
        </div>
      </div>

      {/* Card view */}
      <div data-catalog-view-panel data-view="cards" hidden>
        {/* Flat grid (default) */}
        <div data-platform-view="flat">
          <ServiceCardGrid services={sortedServices} />
        </div>

        {/* Grouped grid (shown when platform grouping is active) */}
        <div data-platform-view="grouped" hidden>
          {platformGroups.map((group) => (
            <div class="platform-section" data-platform-section={group.platform || '__other__'}>
              <div class="platform-section-header">
                <span class="platform-section-label">{group.label}</span>
                <span class="platform-section-count" data-platform-count>{group.services.length}</span>
              </div>
              <ServiceCardGrid services={group.services} />
            </div>
          ))}
        </div>
      </div>

      <script src="../../scripts/catalog-grid.ts"></script>
    </section>
  ) : (
    <Card class="px-6 py-14 text-center">
      <SectionTitle class="mb-2.5">No services found</SectionTitle>
      <p class="muted mx-auto max-w-3xl leading-7">
        No services were discovered from the configured sources yet.
      </p>
    </Card>
  )
}

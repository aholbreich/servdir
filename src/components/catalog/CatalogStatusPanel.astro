---
import {
  getCatalogStatusTabButtonId,
  getCatalogStatusTabPanelId,
  type CatalogStatusTabId,
} from '../../lib/catalog-status';

export interface Props {
  tabsId: string;
  tabId: CatalogStatusTabId;
  active?: boolean;
}

const { tabsId, tabId, active = false } = Astro.props;
---

<!-- Accessible tab panel wrapper that matches a tab button to its content section. -->
<section
  id={getCatalogStatusTabPanelId(tabsId, tabId)}
  class="catalog-status-panel"
  role="tabpanel"
  aria-labelledby={getCatalogStatusTabButtonId(tabsId, tabId)}
  data-catalog-status-panel
  data-tab={tabId}
  hidden={!active}
>
  <slot />
</section>

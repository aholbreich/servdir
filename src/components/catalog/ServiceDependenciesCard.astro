---
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import type { ServiceRecord } from '../../lib/catalog';

export interface DependencyItem {
  id: string;
  service?: ServiceRecord;
}

export interface Props {
  dependencies: DependencyItem[];
}

const { dependencies } = Astro.props;
---

<Card>
  <SectionTitle class="mb-[14px]">Dependencies</SectionTitle>
  {dependencies.length > 0 ? (
    <ul class="grid gap-2 pl-[18px] leading-6">
      {dependencies.map((dependency) => (
        <li>
          {dependency.service ? (
            <a href={`/services/${dependency.service.slug}`}>{dependency.id}</a>
          ) : (
            dependency.id
          )}
        </li>
      ))}
    </ul>
  ) : (
    <p class="muted leading-6">No dependencies declared.</p>
  )}
</Card>

---
import Card from '../ui/Card.astro';
import IssueList from '../ui/IssueList.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import type { ServiceRecord } from '../../lib/catalog';

export interface Props {
  service: ServiceRecord;
}

const { service } = Astro.props;
const hasIssues = service.issues.length > 0;
---

<Card>
  <SectionTitle class="mb-[14px]">Validation</SectionTitle>
  {hasIssues ? (
    <IssueList issues={service.issues} />
  ) : (
    <p class="leading-6 text-[var(--color-ok)]">No validation issues.</p>
  )}
</Card>

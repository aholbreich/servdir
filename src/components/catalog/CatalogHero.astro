---
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';

export interface Props {
  title: string;
  subtitle?: string;
  eyebrow?: string;
}

const {
  title,
  subtitle = 'Git is the database. Markdown files are the source of truth.',
  eyebrow = 'Servdir - Simple Service Catalog',
} = Astro.props;
---

<Card class="p-7">
  <p class="muted mb-2.5 text-[0.82rem] tracking-[0.02em]">{eyebrow}</p>
  <SectionTitle level="h1" class="mb-3 tracking-[-0.03em]">{title}</SectionTitle>
  <p class="muted max-w-5xl leading-7">
    {subtitle}
  </p>
</Card>

---
import Card from '../ui/Card.astro';
import type { PlatformSummary } from '../../lib/catalog';
import { toAppPath } from '../../lib/paths';

export interface Props {
  platforms: PlatformSummary[];
}

const { platforms } = Astro.props;
---

{platforms.length > 0 ? (
  <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {platforms.map((platform) => (
      <Card class="flex items-center justify-between gap-4 px-5 py-4">
        <a href={toAppPath(`/platforms/${platform.slug}`)} class="text-[1rem] font-medium text-slate-800 hover:text-blue-700">
          {platform.label}
        </a>
        <span class="pill">{platform.serviceCount} service{platform.serviceCount === 1 ? '' : 's'}</span>
      </Card>
    ))}
  </section>
) : (
  <Card class="px-6 py-14 text-center">
    <p class="muted mx-auto max-w-3xl leading-7">No platforms were found in the configured services.</p>
  </Card>
)}

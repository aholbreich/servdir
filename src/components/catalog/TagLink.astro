---
import { toTagSlug } from '../../lib/catalog';
import { toAppPath } from '../../lib/paths';

export interface Props {
  tag: string;
  class?: string;
}

const { tag, class: className = '' } = Astro.props;
const slug = toTagSlug(tag);
---

<a href={toAppPath(`/tags/${slug}`)} class:list={['catalog-tag-link font-medium', className]}>#{tag}</a>

---
import Badge from '../ui/Badge.astro';
import Card from '../ui/Card.astro';
import MetadataPill from '../ui/MetadataPill.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import TagLink from './TagLink.astro';
import type { ServiceRecord } from '../../lib/catalog';

export interface Props {
  service: ServiceRecord;
}

const { service } = Astro.props;
const hasIssues = service.issues.length > 0;

const attributeItems = [
  { value: service.data.id },
  { value: service.data.kind },
  { value: service.data.owner },
  { value: service.data.lifecycle },
  ...(service.data.system ? [{ value: service.data.system }] : []),
  ...(service.data.domain ? [{ value: service.data.domain }] : []),
  ...(service.data.tier ? [{ value: `tier ${service.data.tier}` }] : []),
];
---

<Card class="mb-5 p-6.5">
  <div class="flex flex-wrap items-start justify-between gap-4">
    <div>
      <SectionTitle level="h1" class="mb-3">{service.data.name}</SectionTitle>
      <div class="mt-0.5 flex flex-wrap gap-2 text-[0.9rem] leading-5">
        {attributeItems.map((item) => (
          <MetadataPill>{item.value}</MetadataPill>
        ))}
      </div>
    </div>

    <div class="flex flex-wrap justify-end gap-2">
      <Badge tone={hasIssues ? 'warn' : 'ok'}>
        {hasIssues ? `${service.issues.length} issue(s)` : 'valid'}
      </Badge>
      {service.data.tags?.map((tag) => (
        <TagLink tag={tag} class="pill" />
      ))}
    </div>
  </div>
</Card>

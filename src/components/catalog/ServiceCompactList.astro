---
import TagLink from './TagLink.astro';
import type { ServiceRecord } from "../../lib/catalog";

export interface Props {
  services: ServiceRecord[];
}

const { services } = Astro.props;
const idColumnWidthCh = Math.max(...services.map((service) => service.data.id.length), 8);
const tagsColumnWidthCh = Math.max(
  ...services.map((service) =>
    (service.data.tags ?? []).reduce((total, tag, index) => total + tag.length + (index > 0 ? 4 : 1), 0),
  ),
  12,
);
---

<ul
  class="divide-y divide-[var(--color-border)] rounded-2xl border border-[var(--color-border)] bg-white/85 shadow-sm"
  style={`--catalog-id-column: ${idColumnWidthCh}ch; --catalog-tags-column: ${tagsColumnWidthCh}ch;`}
>
  {
    services.map((service) => (
      <li>
        <div class="catalog-list-row catalog-list-grid px-4 py-3 sm:px-5">
          <a href={`/services/${service.slug}`} class="catalog-list-main-link contents">
            <span class="catalog-list-id muted text-[0.84rem]">{service.data.id}</span>

            <span class="catalog-list-row-title min-w-0 truncate text-[1rem] font-semibold text-slate-950">
              {service.data.name}
            </span>

            <span class="catalog-list-status flex shrink-0 items-center gap-2">
              {service.issues.length > 0 ? (
                <span class="pill pill-warn">
                  {service.issues.length} warning
                  {service.issues.length === 1 ? "" : "s"}
                </span>
              ) : (
                <span class="pill pill-ok">ok</span>
              )}
            </span>
          </a>

          <span class="catalog-list-meta flex min-w-0 flex-wrap items-center gap-x-3 gap-y-1 text-[0.9rem] text-slate-700">
            {service.data.tags && service.data.tags.length > 0 && (
              <span class="catalog-list-tags flex min-w-0 flex-wrap gap-x-3 gap-y-1 text-[0.83rem] leading-5 text-sky-700">
                {service.data.tags.map((tag) => (
                  <TagLink tag={tag} />
                ))}
              </span>
            )}
          </span>
        </div>
      </li>
    ))
  }
</ul>

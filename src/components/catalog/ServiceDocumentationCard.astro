---
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';

export interface Props {
  html: string;
}

const { html } = Astro.props;
---

<Card as="article" class="p-6.5">
  <SectionTitle class="mb-3.5">Documentation</SectionTitle>
  <div class="prose-catalog" set:html={html} />
</Card>

<script src="../../scripts/mermaid-render.ts"></script>

<style>
  .mermaid-block {
    margin-block: 1.25rem;
  }

  .mermaid-diagram {
    overflow-x: auto;
  }

  .mermaid-diagram svg {
    max-width: 100%;
    height: auto;
    display: block;
    margin-inline: auto;
  }

  .mermaid-error {
    padding: 0.5rem 0.75rem;
    border-left: 3px solid var(--color-red-400, #f87171);
    background: var(--color-red-50, #fef2f2);
    color: var(--color-red-700, #b91c1c);
    font-size: 0.875rem;
    border-radius: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .mermaid-source {
    margin-top: 0.5rem;
    font-size: 0.8rem;
  }

  .mermaid-source summary {
    cursor: pointer;
    color: var(--color-neutral-500, #737373);
    user-select: none;
    width: fit-content;
  }

  .mermaid-source summary:hover {
    color: var(--color-neutral-700, #404040);
  }

  .mermaid-source pre {
    margin-top: 0.5rem;
    padding: 0.75rem;
    background: var(--color-neutral-50, #fafafa);
    border: 1px solid var(--color-neutral-200, #e5e5e5);
    border-radius: 0.375rem;
    overflow-x: auto;
    font-size: 0.8rem;
    white-space: pre;
  }
</style>

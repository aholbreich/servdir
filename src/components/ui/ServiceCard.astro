---
import CatalogKindIcon from '../catalog/CatalogKindIcon.astro';
import ServiceCardLinkIcon from '../catalog/ServiceCardLinkIcon.astro';
import Card from './Card.astro';
import IssueList from './IssueList.astro';
import TagLink from '../catalog/TagLink.astro';
import { getServiceSummary, type ServiceRecord } from '../../lib/catalog';
import { toAppPath } from '../../lib/paths';
import { getServiceCardLinks } from '../../lib/service-card-links';

export interface Props {
  service: ServiceRecord;
}

const { service } = Astro.props;
const summary = getServiceSummary(service);
const hasIssues = service.issues.length > 0;
const cardLinks = getServiceCardLinks(service.data);
---

<Card as="article" class="flex h-full flex-col px-4 pt-4 pb-3 sm:px-5 sm:pt-5">
  <div>
    <h2
      class="min-w-0 text-[1.2rem] leading-tight font-semibold text-slate-950 sm:text-[1.28rem]"
    >
      <a href={toAppPath(`/services/${service.slug}`)}>{service.data.name}</a>
    </h2>
    <span class="service-card-id muted text-[0.82rem]">
      <CatalogKindIcon kind={service.data.kind} class="service-card-kind-icon" />
      <span>{service.data.id}</span>
    </span>
    {
      service.data.tags && service.data.tags.length > 0 && (
        <p class="mt-1.5 flex flex-wrap gap-x-3 gap-y-1 text-[0.83rem] leading-5 text-sky-700">
          {service.data.tags.map((tag) => (
            <TagLink tag={tag} />
          ))}
        </p>
      )
    }
  </div>

  <p class="mt-3 line-clamp-2 text-[0.98rem] leading-6 text-slate-700">
    {summary}
  </p>

  <div
    class="mt-auto flex flex-wrap items-center justify-between gap-x-4 gap-y-2 border-t border-[var(--color-border)]/70 pt-3 text-[0.95rem]"
  >
    <div class="flex flex-wrap items-center gap-2">
      {cardLinks.map((link) => (
        <ServiceCardLinkIcon kind={link.kind} href={link.href} label={link.label} />
      ))}
    </div>
    <a href={toAppPath(`/services/${service.slug}`)}>View details →</a>
  </div>

  {hasIssues && <IssueList issues={service.issues} class="mt-3 gap-1.5" />}
</Card>

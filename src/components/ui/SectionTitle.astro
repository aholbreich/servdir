---
export interface Props {
  class?: string;
  level?: 'h1' | 'h2' | 'h3';
}

const { class: className = '', level = 'h2' } = Astro.props;
const Tag = level;
const sizeClass = level === 'h1'
  ? 'text-4xl leading-tight md:text-5xl'
  : level === 'h3'
    ? 'text-lg'
    : 'text-xl';
---

<Tag class:list={['font-semibold text-slate-950', sizeClass, className]}>
  <slot />
</Tag>

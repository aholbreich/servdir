---
export interface Props {
  icon?: string;
  class?: string;
}

const { icon, class: className = '' } = Astro.props;
---

<span class:list={[
  'inline-flex items-center gap-1.5 rounded-full border border-[var(--color-border)]/70 bg-[var(--color-surface-2)] px-2.5 py-1 text-slate-700',
  className,
]}>
  {icon && <span aria-hidden="true">{icon}</span>}
  <span><slot /></span>
</span>

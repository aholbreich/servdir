---
import '../styles/global.css';
import { ThemeToggle } from '../components/ui/ThemeToggle';
import { toAppPath } from '../lib/paths';
import { loadTheme, themeToStyleBlock } from '../lib/theme';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const theme = loadTheme();
const themeStyle = theme ? themeToStyleBlock(theme) : null;
const fontHref = theme?.fonts?.cssImportHref;
const resolveBrandAsset = (value: string | undefined): string | undefined =>
  value && value.startsWith('/') && !value.startsWith('//') ? toAppPath(value) : value;
const faviconHref = resolveBrandAsset(theme?.brand?.faviconUrl) ?? toAppPath('/favicon.svg');
const logoHref = resolveBrandAsset(theme?.brand?.logoUrl);
const darkAvailable = !theme || theme.dark != null;
const bootScript = darkAvailable
  ? `const theme = localStorage.getItem('theme') ?? 'system';
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (theme === 'dark' || (theme === 'system' && prefersDark)) {
      document.documentElement.classList.add('dark');
    }`
  : `document.documentElement.classList.remove('dark');`;
---

<!doctype html>
<html lang="en" data-theme={theme ? 'custom' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    {!theme?.brand?.faviconUrl && (
      <link rel="icon" type="image/x-icon" href={toAppPath('/favicon.ico')} sizes="any" />
    )}
    {fontHref && <link rel="stylesheet" href={fontHref} />}
    <title>{title}</title>
    {themeStyle && <style is:inline set:html={themeStyle} />}
    <script is:inline set:html={bootScript} />
  </head>
  <body>
    <div class="relative">
      {logoHref && (
        <div class="absolute top-4 left-5 z-50">
          <img src={logoHref} alt="" class="h-8 w-auto" />
        </div>
      )}
      <div class="absolute top-4 right-5 z-50">
        <ThemeToggle client:load darkAvailable={darkAvailable} />
      </div>
      <main class="mx-auto max-w-7xl px-5 py-9 md:px-6 md:pb-18">
        <slot />
      </main>
    </div>
  </body>
</html>

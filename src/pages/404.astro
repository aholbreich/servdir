---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { toAppPath } from '@/lib/paths';
---

<BaseLayout title="Not found — servdir">
  <div class="mx-auto mt-16 max-w-[720px] rounded-2xl border border-border bg-card px-6 py-14 text-center shadow-sm">
    <p class="text-eyebrow text-muted-foreground mb-2.5">404</p>
    <h1 class="text-headline mb-3">Page not found</h1>
    <p class="text-body text-muted-foreground mx-auto mb-[22px] max-w-3xl">
      The page you requested does not exist, or the referenced service could not be resolved.
    </p>
    <a class="inline-flex rounded-full border border-border bg-muted px-2.5 py-1 text-sm" href={toAppPath('/')}>
      Back to catalog
    </a>
  </div>
</BaseLayout>

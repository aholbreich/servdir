---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — servdir">
  <section class="card empty-state" style="max-width:720px;margin:64px auto 0;">
    <p class="muted" style="margin:0 0 10px;letter-spacing:0.04em;text-transform:uppercase;font-size:0.82rem;">404</p>
    <h1 style="margin:0 0 12px;font-size:2.2rem;">Page not found</h1>
    <p class="muted" style="margin:0 auto 22px;max-width:56ch;line-height:1.7;">
      The page you requested does not exist, or the referenced service could not be resolved.
    </p>
    <a class="pill" href="/" style="display:inline-flex;">Back to catalog</a>
  </section>
</BaseLayout>

---
import ServiceDependenciesCard from '../../components/catalog/ServiceDependenciesCard.astro';
import ServiceDocumentationCard from '../../components/catalog/ServiceDocumentationCard.astro';
import ServiceHeader from '../../components/catalog/ServiceHeader.astro';
import ServiceMetadataCard from '../../components/catalog/ServiceMetadataCard.astro';
import ServiceValidationCard from '../../components/catalog/ServiceValidationCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getConfig } from '../../lib/config';
import { loadCatalog } from '../../lib/catalog';

const config = getConfig();
const id = Astro.params.id;
console.info(`[page:/services/[id]] rendering service route for id=${id}`);
const catalog = await loadCatalog(config.localCatalogPath, {
  gitSources: config.gitSources,
});
const service = catalog.services.find((entry) => entry.slug === id || entry.data.id === id);

if (!service) {
  console.warn(`[page:/services/[id]] service not found for id=${id}`);
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404',
    },
  });
}

const dependencies = (service.data.depends_on ?? []).map((dependencyId) => ({
  id: dependencyId,
  service: catalog.servicesById.get(dependencyId),
}));
---

<BaseLayout title={`${service.data.name} — servdir`}>
  <p class="mb-4"><a href="/">← Back to catalog</a></p>

  <ServiceHeader service={service} />

  <section class="grid items-start gap-5 xl:grid-cols-[minmax(0,2fr)_minmax(300px,1fr)]">
    <ServiceDocumentationCard html={service.html} />

    <aside class="grid gap-[18px]">
      <ServiceMetadataCard service={service} />
      <ServiceDependenciesCard dependencies={dependencies} />
      <ServiceValidationCard service={service} />
    </aside>
  </section>
</BaseLayout>

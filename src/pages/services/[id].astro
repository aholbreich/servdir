---
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';
import IssueList from '../../components/ui/IssueList.astro';
import KeyValueList from '../../components/ui/KeyValueList.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getConfig } from '../../lib/config';
import { loadCatalog } from '../../lib/catalog';

const config = getConfig();
const id = Astro.params.id;
console.info(`[page:/services/[id]] rendering service route for id=${id}`);
const catalog = await loadCatalog(config.catalogPath, {
  gitSources: config.gitSources,
});
const service = catalog.services.find((entry) => entry.slug === id || entry.data.id === id);

if (!service) {
  console.warn(`[page:/services/[id]] service not found for id=${id}`);
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404',
    },
  });
}

const dependencies = service.data.depends_on ?? [];
const hasIssues = service.issues.length > 0;
const metadataItems = [
  { label: 'Repository', href: service.data.repo, text: 'Open repository ↗' },
  { label: 'Runbook', href: service.data.runbook, text: 'Open runbook ↗' },
  { label: 'System', value: service.data.system },
  { label: 'Domain', value: service.data.domain },
  ...(service.data.links ?? []).map((link) => ({
    label: link.label,
    href: link.url,
    text: 'Visit ↗',
  })),
];
---

<BaseLayout title={`${service.data.name} — servdir`}>
  <p class="mb-4"><a href="/">← Back to catalog</a></p>

  <Card class="mb-5 p-[26px]">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="muted mb-2 text-[0.82rem] uppercase tracking-[0.03em]">Service</p>
        <SectionTitle level="h1" class="mb-3">{service.data.name}</SectionTitle>
        <div class="muted flex flex-wrap gap-3 leading-6">
          <span>ID: {service.data.id}</span>
          <span>Owner: {service.data.owner}</span>
          <span>Lifecycle: {service.data.lifecycle}</span>
          {service.data.system && <span>System: {service.data.system}</span>}
          {service.data.domain && <span>Domain: {service.data.domain}</span>}
          {service.data.tier && <span>Tier: {service.data.tier}</span>}
        </div>
      </div>
      <div class="flex flex-wrap justify-end gap-2">
        <Badge tone={hasIssues ? 'warn' : 'ok'}>
          {hasIssues ? `${service.issues.length} issue(s)` : 'valid'}
        </Badge>
        {service.data.tags?.map((tag) => <Badge>#{tag}</Badge>)}
      </div>
    </div>
  </Card>

  <section class="grid items-start gap-5 xl:grid-cols-[minmax(0,2fr)_minmax(300px,1fr)]">
    <Card as="article" class="p-[26px]">
      <SectionTitle class="mb-[14px]">Documentation</SectionTitle>
      <div class="prose-catalog" set:html={service.html} />
    </Card>

    <aside class="grid gap-[18px]">
      <Card>
        <SectionTitle class="mb-[14px]">Metadata</SectionTitle>
        <KeyValueList items={metadataItems} />
      </Card>

      <Card>
        <SectionTitle class="mb-[14px]">Dependencies</SectionTitle>
        {dependencies.length > 0 ? (
          <ul class="grid gap-2 pl-[18px] leading-6">
            {dependencies.map((dependency) => <li>{dependency}</li>)}
          </ul>
        ) : (
          <p class="muted leading-6">No dependencies declared.</p>
        )}
      </Card>

      <Card>
        <SectionTitle class="mb-[14px]">Validation</SectionTitle>
        {hasIssues ? (
          <IssueList issues={service.issues} />
        ) : (
          <p class="leading-6 text-[var(--color-ok)]">No validation issues.</p>
        )}
      </Card>
    </aside>
  </section>
</BaseLayout>

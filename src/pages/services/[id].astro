---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getConfig } from '../../lib/config';
import { loadCatalog } from '../../lib/catalog';

const config = getConfig();
const id = Astro.params.id;
console.info(`[page:/services/[id]] rendering service route for id=${id} with catalog path ${config.catalogPath}`);
const catalog = await loadCatalog(config.catalogPath);
const service = catalog.services.find((entry) => entry.slug === id || entry.data.id === id);

if (!service) {
  console.warn(`[page:/services/[id]] service not found for id=${id}`);
  return new Response(null, {
    status: 404,
    headers: {
      Location: '/404',
    },
  });
}

const dependencies = service.data.depends_on ?? [];
const hasIssues = service.issues.length > 0;
---

<BaseLayout title={`${service.data.name} — servdir`}>
  <p class="mb-4"><a href="/">← Back to catalog</a></p>

  <section class="card mb-5 p-[26px]">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="muted mb-2 text-[0.82rem] uppercase tracking-[0.03em]">Service</p>
        <h1 class="mb-3 text-4xl leading-tight font-semibold text-slate-950">{service.data.name}</h1>
        <div class="muted flex flex-wrap gap-3 leading-6">
          <span>ID: {service.data.id}</span>
          <span>Owner: {service.data.owner}</span>
          <span>Lifecycle: {service.data.lifecycle}</span>
          {service.data.tier && <span>Tier: {service.data.tier}</span>}
        </div>
      </div>
      <div class="flex flex-wrap justify-end gap-2">
        <span class:list={['pill', hasIssues ? 'pill-warn' : 'pill-ok']}>
          {hasIssues ? `${service.issues.length} issue(s)` : 'valid'}
        </span>
        {service.data.tags?.map((tag) => <span class="pill">#{tag}</span>)}
      </div>
    </div>
  </section>

  <section class="grid items-start gap-5 xl:grid-cols-[minmax(0,2fr)_minmax(300px,1fr)]">
    <article class="card p-[26px]">
      <h2 class="mb-[14px] text-xl font-semibold text-slate-950">Documentation</h2>
      <div class="prose-catalog" set:html={service.html} />
    </article>

    <aside class="grid gap-[18px]">
      <section class="card">
        <h2 class="mb-[14px] text-xl font-semibold text-slate-950">Metadata</h2>
        <ul class="grid list-none gap-3 p-0 leading-6">
          <li><strong class="font-semibold text-slate-950">Repository:</strong><br /><a href={service.data.repo} target="_blank" rel="noreferrer">{service.data.repo}</a></li>
          {service.data.runbook && <li><strong class="font-semibold text-slate-950">Runbook:</strong><br /><a href={service.data.runbook} target="_blank" rel="noreferrer">{service.data.runbook}</a></li>}
          {service.data.system && <li><strong class="font-semibold text-slate-950">System:</strong> {service.data.system}</li>}
          {service.data.domain && <li><strong class="font-semibold text-slate-950">Domain:</strong> {service.data.domain}</li>}
        </ul>
      </section>

      <section class="card">
        <h2 class="mb-[14px] text-xl font-semibold text-slate-950">Dependencies</h2>
        {dependencies.length > 0 ? (
          <ul class="grid gap-2 pl-[18px] leading-6">
            {dependencies.map((dependency) => <li>{dependency}</li>)}
          </ul>
        ) : (
          <p class="muted leading-6">No dependencies declared.</p>
        )}
      </section>

      <section class="card">
        <h2 class="mb-[14px] text-xl font-semibold text-slate-950">Validation</h2>
        {hasIssues ? (
          <ul class="grid gap-2 pl-[18px] leading-6">
            {service.issues.map((issue) => (
              <li class={issue.level === 'error' ? 'issue-error' : 'issue-warning'}>{issue.message}</li>
            ))}
          </ul>
        ) : (
          <p class="leading-6 text-[var(--color-ok)]">No validation issues.</p>
        )}
      </section>
    </aside>
  </section>
</BaseLayout>

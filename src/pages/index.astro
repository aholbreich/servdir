---
import Badge from '../components/ui/Badge.astro';
import Card from '../components/ui/Card.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import ServiceCatalogGrid from '../components/catalog/ServiceCatalogGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getConfig } from '../lib/config';
import { loadCatalog } from '../lib/catalog';

const config = getConfig();
console.info('[page:/] rendering catalog index');
const catalog = await loadCatalog(config.localCatalogPath, { gitSources: config.gitSources, });
const servicesWithIssues = catalog.services.filter((service) => service.issues.length > 0).length;
const servicesValid = catalog.services.length - servicesWithIssues;
---

<BaseLayout title="servdir — Service Catalog">
  <section class="mb-7 grid items-stretch gap-5 lg:grid-cols-[minmax(0,1.8fr)_minmax(280px,0.9fr)]">
    <Card class="p-7">
      <p class="muted mb-2.5 text-[0.82rem] uppercase tracking-[0.02em]">Simple Service Catalog</p>
      <SectionTitle level="h1" class="mb-3 tracking-[-0.03em]">Service Catalog</SectionTitle>
      <p class="muted max-w-5xl leading-7">
        Git is the database. Markdown files are the source of truth. 
      </p>

      <div class="my-5 h-px bg-linear-to-r from-transparent via-[var(--color-border)] to-transparent"></div>

      <div class="flex flex-wrap gap-2.5">
        <Badge tone="ok">{servicesValid} valid</Badge>
        {servicesWithIssues > 0 ? <Badge tone="warn">{servicesWithIssues} with issues</Badge> : <Badge>No current warnings</Badge>}
        {config.localCatalogPath && <Badge>Catalog path: <code>{config.localCatalogPath}</code></Badge>}
      </div>
    </Card>

    <Card as="aside">
      <SectionTitle class="mb-3 text-lg">Catalog status</SectionTitle>
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-2xl border border-[var(--color-border)]/50 bg-[var(--color-surface-2)] p-3.5">
          <div class="muted mb-1 text-[0.85rem]">Services</div>
          <div class="text-xl font-semibold text-slate-950">{catalog.services.length}</div>
        </div>
        <div class="rounded-2xl border border-[var(--color-border)]/50 bg-[var(--color-surface-2)] p-3.5">
          <div class="muted mb-1 text-[0.85rem]">Generated</div>
          <div class="text-base font-semibold text-slate-950">{new Date(catalog.generatedAt).toLocaleString('en-GB')}</div>
        </div>
      </div>
      <p class="muted mt-4 leading-6">
      
      </p>
    </Card>
  </section>

  <ServiceCatalogGrid services={catalog.services} />
</BaseLayout>

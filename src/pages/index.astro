---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getConfig } from '../lib/config';
import { loadCatalog } from '../lib/catalog';

const config = getConfig();
console.info(`[page:/] rendering catalog index with catalog path ${config.catalogPath}`);
const catalog = await loadCatalog(config.catalogPath);
const servicesWithIssues = catalog.services.filter((service) => service.issues.length > 0).length;
const servicesValid = catalog.services.length - servicesWithIssues;
---

<BaseLayout title="servdir — Service Catalog">
  <section class="mb-7 grid items-stretch gap-5 lg:grid-cols-[minmax(0,1.8fr)_minmax(280px,0.9fr)]">
    <div class="card p-7">
      <p class="muted mb-2.5 text-[0.82rem] uppercase tracking-[0.02em]">Simple service catalog for engineers</p>
      <h1 class="mb-3 text-4xl leading-tight font-semibold tracking-[-0.03em] text-slate-950 md:text-5xl">Service Catalog</h1>
      <p class="muted max-w-5xl leading-7">
        Git is the database. Markdown files are the source of truth. This MVP reads service definitions,
        validates them, and renders a browsable catalog with just enough structure to beat handwritten wiki pages.
      </p>

      <div class="my-5 h-px bg-linear-to-r from-transparent via-[var(--color-border)] to-transparent"></div>

      <div class="flex flex-wrap gap-2.5">
        <span class="pill pill-ok">{servicesValid} valid</span>
        {servicesWithIssues > 0 ? <span class="pill pill-warn">{servicesWithIssues} with issues</span> : <span class="pill">No current warnings</span>}
        <span class="pill">Catalog path: <code>{config.catalogPath}</code></span>
      </div>
    </div>

    <aside class="card">
      <h2 class="mb-3 text-lg font-semibold text-slate-950">Catalog status</h2>
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-2xl border border-white/5 bg-white/2 p-3.5">
          <div class="muted mb-1 text-[0.85rem]">Services</div>
          <div class="text-xl font-semibold text-slate-950">{catalog.services.length}</div>
        </div>
        <div class="rounded-2xl border border-white/5 bg-white/2 p-3.5">
          <div class="muted mb-1 text-[0.85rem]">Generated</div>
          <div class="text-base font-semibold text-slate-950">{new Date(catalog.generatedAt).toLocaleString('en-GB')}</div>
        </div>
      </div>
      <p class="muted mt-4 leading-6">
        The catalog is built in memory at runtime from Markdown files in the configured catalog directory.
      </p>
    </aside>
  </section>

  {catalog.services.length > 0 ? (
    <section class="grid gap-[18px]">
      {catalog.services.map((service) => {
        const summary = service.data.description
          ?? service.body.split('\n').find((line) => line.trim() && !line.trim().startsWith('#'))
          ?? 'No description provided.';
        const hasIssues = service.issues.length > 0;

        return (
          <article class="card px-[22px] pt-[22px] pb-[18px]">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="muted mb-2 text-[0.86rem]">{service.data.id}</div>
                <h2 class="mb-2.5 text-[1.35rem] leading-tight font-semibold text-slate-950">
                  <a href={`/services/${service.slug}`}>{service.data.name}</a>
                </h2>
                <div class="muted flex flex-wrap gap-3 leading-6">
                  <span><strong class="font-semibold text-slate-950">Owner:</strong> {service.data.owner}</span>
                  <span><strong class="font-semibold text-slate-950">Lifecycle:</strong> {service.data.lifecycle}</span>
                  {service.data.tier && <span><strong class="font-semibold text-slate-950">Tier:</strong> {service.data.tier}</span>}
                </div>
              </div>

              <div class="flex max-w-full flex-wrap justify-end gap-2">
                <span class:list={['pill', hasIssues ? 'pill-warn' : 'pill-ok']}>
                  {hasIssues ? `${service.issues.length} issue(s)` : 'valid'}
                </span>
                {service.data.tags?.map((tag) => <span class="pill">#{tag}</span>)}
              </div>
            </div>

            <p class="my-[18px] max-w-4xl leading-7 text-slate-700">
              {summary}
            </p>

            <div class="flex flex-wrap items-center justify-between gap-4 border-t border-white/6 pt-2">
              <a href={service.data.repo} target="_blank" rel="noreferrer">Repository</a>
              <a href={`/services/${service.slug}`}>View details →</a>
            </div>

            {hasIssues && (
              <ul class="mt-4 grid gap-1.5 pl-[18px]">
                {service.issues.map((issue) => (
                  <li class={issue.level === 'error' ? 'issue-error' : 'issue-warning'}>{issue.message}</li>
                ))}
              </ul>
            )}
          </article>
        );
      })}
    </section>
  ) : (
    <section class="card px-6 py-14 text-center">
      <h2 class="mb-2.5 text-2xl font-semibold text-slate-950">No services found</h2>
      <p class="muted mx-auto max-w-3xl leading-7">
        No <code>service.md</code> files were discovered under <code>{config.catalogPath}</code>. Add entries below
        <code>services/&lt;service-id&gt;/service.md</code> to populate the catalog.
      </p>
    </section>
  )}
</BaseLayout>

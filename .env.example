LOCAL_CATALOG_PATH=./catalog

# Optional build/version string shown in the status card
APP_BUILD_VERSION=

# Optional catalog title override
CATALOG_TITLE="Service Catalog - My Company"

# Optional logging controls
#LOG_FORMAT=json
#LOG_LEVEL=info
#LOG_COLOR=auto

# Optional Basic Auth protection
BASIC_AUTH_ENABLED=
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Optional managed git source sync interval (e.g. 30s, 5m, 1h — plain number is seconds, default: 1m)
GIT_SYNC_INTERVAL=1m

# Optional managed git sources — one variable per source
# Format: GIT_SOURCE_<NAME>=repoUrl|branch[|scanPath1,scanPath2]
# Name is derived from the variable suffix: CATALOG_MAIN -> catalog-main
# Omit scanPaths to scan the entire repo root.
# Examples:
# GIT_SOURCE_CATALOG_MAIN=git@bitbucket.org:your-org/servdir-catalog.git|main|services
# GIT_SOURCE_PLATFORM=git@bitbucket.org:your-org/platform.git|main|services,platform/services
# GIT_SOURCE_MONOREPO=git@bitbucket.org:your-org/monorepo.git|main

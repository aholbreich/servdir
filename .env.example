LOCAL_CATALOG_PATH=./catalog

# Optional build/version string shown in the status card
APP_BUILD_VERSION=

# Optional catalog title override
CATALOG_TITLE="Service Catalog - My Company"

# Optional Basic Auth protection
BASIC_AUTH_ENABLED=
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Optional managed git source sync interval in milliseconds
GIT_SYNC_INTERVAL_MS=60000

# Optional managed git sources as JSON array
# Example:
# GIT_SOURCES=[{"name":"catalog-main","repoUrl":"git@bitbucket.org:yourorg/service-catalog.git","branch":"main","checkoutPath":"/data/catalog-cache/catalog-main","scanPaths":["services"]}]
GIT_SOURCES=

LOCAL_CATALOG_PATH=./catalog

# Optional build/version string shown in the status card
APP_BUILD_VERSION=

# Optional catalog title override
CATALOG_TITLE="Service Catalog - My Company"

# Optional logging controls
#LOG_FORMAT=json
#LOG_LEVEL=info
#LOG_COLOR=auto

# Authentication mode — one of: none | basic | oidc (default: none)
# See .adr/012-app-level-oidc-login-with-microsoft-entra.md for the full story.
AUTH_MODE=

# Basic Auth (only honored when AUTH_MODE=basic, or unset + BASIC_AUTH_ENABLED=true legacy)
BASIC_AUTH_ENABLED=
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# Microsoft Entra OIDC (required when AUTH_MODE=oidc)
# Tenant + client come from the Entra App Registration.
AUTH_OIDC_TENANT_ID=
AUTH_OIDC_CLIENT_ID=
AUTH_OIDC_CLIENT_SECRET=
# Must match the Redirect URI registered in the Entra app.
AUTH_OIDC_REDIRECT_URI=https://your-host.example.com/auth/callback
# 32+ random bytes (base64). Generate with: openssl rand -base64 32
# Rotating this invalidates all live sessions instantly (re-login wave expected).
AUTH_SESSION_SECRET=
# Optional session lifetime in hours. Default 8, range 1..168.
#AUTH_SESSION_TTL_HOURS=8

# Optional managed git source sync interval (e.g. 30s, 5m, 1h — plain number is seconds, default: 1m)
GIT_SYNC_INTERVAL=1m

# Optional managed git sources — one variable per source
# Format: GIT_SOURCE_<NAME>=repoUrl|branch[|scanPath1,scanPath2]
# Name is derived from the variable suffix: CATALOG_MAIN -> catalog-main
# Omit scanPaths to scan the entire repo root.
# Examples:
# GIT_SOURCE_CATALOG_MAIN=git@bitbucket.org:your-org/servdir-catalog.git|main|services
# GIT_SOURCE_PLATFORM=git@bitbucket.org:your-org/platform.git|main|services,platform/services
# GIT_SOURCE_MONOREPO=git@bitbucket.org:your-org/monorepo.git|main
